{
  "name": "Benedict's Portfolio Development",
  "description": "Modern portfolio website with enhanced features",
  "version": "2.0.0",
  "author": "Benedict Amankwa Osei",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/benedictamankw18/updateCv.git"
  },
  "homepage": "https://benedictamankw.dev",
  "keywords": [
    "portfolio",
    "cv",
    "resume",
    "web-developer",
    "full-stack",
    "cybersecurity",
    "modern",
    "responsive"
  ],
  "scripts": {
    "start": "python -m http.server 8000",
    "dev": "python -m http.server 8000",
    "build": "echo 'Building project...' && npm run minify",
    "minify": "echo 'Minifying assets...'",
    "lint": "echo 'Linting code...'",
    "test": "echo 'Running tests...'",
    "deploy": "echo 'Deploying to production...'"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "lighthouse": "^10.4.0",
    "axe-core": "^4.8.2"
  },
  "engines": {
    "node": ">=14.0.0",
    "python": ">=3.7.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie <= 11"
  ],
  "configuration": {
    "development": {
      "port": 8000,
      "host": "localhost",
      "https": false,
      "livereload": true
    },
    "production": {
      "minify": true,
      "compress": true,
      "cache": true,
      "analytics": true
    }
  },
  "features": {
    "responsive_design": true,
    "progressive_web_app": true,
    "service_worker": true,
    "offline_support": true,
    "accessibility": true,
    "seo_optimized": true,
    "performance_optimized": true,
    "modern_css": true,
    "modern_javascript": true,
    "contact_form": true,
    "project_filtering": true,
    "smooth_animations": true,
    "lazy_loading": true,
    "dark_mode": false,
    "multi_language": false
  },
  "tech_stack": {
    "frontend": [
      "HTML5",
      "CSS3",
      "JavaScript (ES6+)",
      "Service Worker"
    ],
    "styling": [
      "CSS Grid",
      "Flexbox",
      "CSS Custom Properties",
      "Responsive Design",
      "Animations"
    ],
    "tools": [
      "Git",
      "VS Code",
      "Font Awesome",
      "Google Fonts"
    ],
    "performance": [
      "Lazy Loading",
      "Service Worker",
      "Image Optimization",
      "Critical CSS",
      "Minification"
    ]
  },
  "sections": {
    "hero": {
      "enabled": true,
      "features": ["typing_effect", "stats", "cta_buttons"]
    },
    "about": {
      "enabled": true,
      "features": ["personal_info", "education", "highlights"]
    },
    "skills": {
      "enabled": true,
      "features": ["progress_bars", "skill_tags", "tools_grid"]
    },
    "experience": {
      "enabled": true,
      "features": ["timeline", "education", "achievements"]
    },
    "projects": {
      "enabled": true,
      "features": ["filtering", "grid_layout", "modal_preview"]
    },
    "contact": {
      "enabled": true,
      "features": ["contact_form", "social_links", "contact_methods"]
    },
    "certifications": {
      "enabled": true,
      "features": ["carousel", "lazy_loading"]
    }
  },
  "performance_targets": {
    "lighthouse": {
      "performance": 90,
      "accessibility": 95,
      "best_practices": 90,
      "seo": 95
    },
    "core_web_vitals": {
      "lcp": "< 2.5s",
      "fid": "< 100ms",
      "cls": "< 0.1"
    },
    "page_speed": {
      "mobile": 85,
      "desktop": 95
    }
  },
  "deployment": {
    "platforms": [
      "GitHub Pages",
      "Netlify",
      "Vercel",
      "Traditional Hosting"
    ],
    "domains": [
      "benedictamankw.dev",
      "benedictamankw.github.io"
    ],
    "ssl": true,
    "cdn": true,
    "compression": true
  },
  "analytics": {
    "google_analytics": "GA_TRACKING_ID",
    "performance_monitoring": true,
    "error_tracking": true,
    "user_behavior": true
  },
  "seo": {
    "structured_data": true,
    "open_graph": true,
    "twitter_cards": true,
    "sitemap": true,
    "robots_txt": true,
    "canonical_urls": true
  },
  "security": {
    "content_security_policy": true,
    "https_only": true,
    "input_validation": true,
    "xss_protection": true
  },
  "accessibility": {
    "wcag_compliance": "AA",
    "screen_reader_support": true,
    "keyboard_navigation": true,
    "color_contrast": "AA",
    "alt_texts": true,
    "aria_labels": true
  },
  "browser_support": {
    "chrome": "latest",
    "firefox": "latest",
    "safari": "latest",
    "edge": "latest",
    "mobile": "latest"
  },
  "file_structure": {
    "assets/": "Static assets (CSS, JS, images)",
    "docs/": "Documentation and guides",
    "font-awesome-4.7.0/": "Icon library",
    "index.html": "Original homepage",
    "index-enhanced.html": "Enhanced modern homepage",
    "style.css": "Original styles",
    "assets/css/enhanced-styles.css": "Modern enhanced styles",
    "script.js": "Original JavaScript",
    "assets/js/enhanced-app.js": "Modern JavaScript functionality",
    "sw.js": "Service Worker for PWA",
    "contact.php": "Contact form handler",
    "README.md": "Project documentation"
  },
  "development_workflow": {
    "1": "Clone repository",
    "2": "Start local server",
    "3": "Make changes",
    "4": "Test locally",
    "5": "Commit changes",
    "6": "Push to repository",
    "7": "Deploy to production"
  },
  "roadmap": [
    "Dark mode implementation",
    "Blog section integration",
    "Advanced animations",
    "Multi-language support",
    "CMS integration",
    "AI chatbot",
    "3D elements"
  ]
}
